{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://127.0.0.1:47625/claude-code/stop -H 'content-type: application/json' --max-time 5 -d @- > /dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST http://127.0.0.1:47625/claude-code/notification -H 'content-type: application/json' --max-time 5 -d @- > /dev/null || true"
          }
        ]
      }
    ]
  }
}
